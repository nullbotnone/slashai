---
interface Props {
  variant?: 'default' | 'compact';
  title?: string;
  description?: string;
}

const {
  variant = 'default',
  title = 'AI tools that work, in your inbox.',
  description = 'Weekly picks, honest reviews, and workflow tips. No spam — unsubscribe anytime.'
} = Astro.props;
---

<section class={`newsletter ${variant}`}>
  <div class="newsletter-inner">
    <h3>{title}</h3>
    {variant === 'default' && <p>{description}</p>}
    <form
      class="newsletter-form"
      action="https://buttondown.com/api/emails/embed-subscribe/nullbot"
      method="post"
      target="popupwindow"
      onsubmit="window.open('https://buttondown.com/nullbot', 'popupwindow')"
    >
      <input
        type="email"
        name="email"
        placeholder="you@email.com"
        required
        class="newsletter-input"
      />
      <button type="submit" class="newsletter-btn">Subscribe</button>
    </form>
    <span class="newsletter-note">Free forever. Unsubscribe in one click.</span>
  </div>
</section>

<style>
  .newsletter {
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem;
    margin: 3.5rem 0;
    text-align: center;
  }

  .newsletter.compact {
    padding: 1.5rem 1.25rem;
    margin: 2.25rem 0;
  }

  .newsletter h3 {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
    color: var(--color-text);
  }

  .newsletter.compact h3 {
    font-size: 1.05rem;
  }

  .newsletter p {
    color: var(--color-text-secondary);
    font-size: 0.925rem;
    max-width: 440px;
    margin: 0 auto 1.5rem;
    line-height: 1.55;
  }

  .newsletter-form {
    display: flex;
    gap: 0.4rem;
    max-width: 420px;
    margin: 0 auto;
  }

  .newsletter-input {
    flex: 1;
    padding: 0.6rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.925rem;
    transition: border-color 0.18s var(--ease-out), box-shadow 0.18s var(--ease-out);
  }

  .newsletter-input::placeholder {
    color: var(--color-text-tertiary);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-ring);
  }

  .newsletter-btn {
    padding: 0.6rem 1.1rem;
    background: var(--color-text);
    color: var(--color-bg);
    border: 1px solid var(--color-text);
    border-radius: var(--radius-sm);
    font-weight: 500;
    font-size: 0.9rem;
    font-family: inherit;
    cursor: pointer;
    transition: transform 0.18s var(--ease-out), box-shadow 0.18s var(--ease-out);
    white-space: nowrap;
  }

  .newsletter-btn:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .newsletter-note {
    display: block;
    margin-top: 0.85rem;
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  @media (max-width: 480px) {
    .newsletter-form {
      flex-direction: column;
    }
    .newsletter-btn {
      padding: 0.75rem;
    }
    .newsletter {
      padding: 2rem 1.25rem;
    }
  }
</style>
