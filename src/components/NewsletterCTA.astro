---
interface Props {
  variant?: 'default' | 'compact';
  title?: string;
  description?: string;
}

const {
  variant = 'default',
  title = 'A weekly dispatch on AI tools that actually work.',
  description = "Picks, reviews, and workflow notes — sent once a week. No spam, unsubscribe anytime."
} = Astro.props;
---

<section class={`newsletter ${variant}`}>
  <div class="newsletter-inner">
    <span class="newsletter-kicker">The Dispatch</span>
    <h3>{title}</h3>
    {variant === 'default' && <p>{description}</p>}
    <form
      class="newsletter-form"
      action="https://buttondown.com/api/emails/embed-subscribe/nullbot"
      method="post"
      target="popupwindow"
      onsubmit="window.open('https://buttondown.com/nullbot', 'popupwindow')"
    >
      <input
        type="email"
        name="email"
        placeholder="you@email.com"
        required
        class="newsletter-input"
        aria-label="Email address"
      />
      <button type="submit" class="newsletter-btn">Subscribe</button>
    </form>
    <span class="newsletter-note">Free forever. Unsubscribe in one click.</span>
  </div>
</section>

<style>
  .newsletter {
    margin: 4rem 0 1.5rem;
    padding: 2.75rem 2rem;
    border-top: 3px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    background: var(--color-bg-subtle);
    text-align: center;
  }

  .newsletter.compact {
    padding: 1.75rem 1.25rem;
    margin: 2.5rem 0 1rem;
  }

  .newsletter-kicker {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.85rem;
  }

  .newsletter h3 {
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.4vw, 1.75rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.18;
    color: var(--color-ink);
    margin: 0 auto 0.75rem;
    max-width: 32ch;
    font-variation-settings: "opsz" 72, "SOFT" 25;
  }

  .newsletter.compact h3 {
    font-size: 1.15rem;
  }

  .newsletter p {
    font-family: var(--font-serif);
    color: var(--color-ink-muted);
    font-size: 1rem;
    line-height: 1.55;
    max-width: 44ch;
    margin: 0 auto 1.5rem;
    font-variation-settings: "opsz" 20, "SOFT" 30;
  }

  .newsletter-form {
    display: flex;
    gap: 0.4rem;
    max-width: 460px;
    margin: 0 auto;
  }

  .newsletter-input {
    flex: 1;
    padding: 0.7rem 0.95rem;
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    transition: border-color 0.18s var(--ease-out), box-shadow 0.18s var(--ease-out);
  }

  .newsletter-input::placeholder {
    color: var(--color-ink-faint);
    font-style: italic;
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-ring);
  }

  .newsletter-btn {
    padding: 0.7rem 1.25rem;
    background: var(--color-ink);
    color: var(--color-bg);
    border: 1px solid var(--color-ink);
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    cursor: pointer;
    transition: background 0.18s var(--ease-out), color 0.18s var(--ease-out);
    white-space: nowrap;
  }

  .newsletter-btn:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-bg);
  }

  .newsletter-note {
    display: block;
    margin-top: 0.95rem;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-faint);
  }

  @media (max-width: 480px) {
    .newsletter-form {
      flex-direction: column;
    }
    .newsletter-btn {
      padding: 0.85rem;
    }
    .newsletter {
      padding: 2.25rem 1.25rem;
    }
  }
</style>
