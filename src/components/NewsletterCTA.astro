---
interface Props {
  variant?: 'default' | 'compact';
  title?: string;
  description?: string;
}

const { 
  variant = 'default',
  title = 'Get AI tools that actually work in your inbox',
  description = 'Weekly picks, honest reviews, and workflow tips. No spam, unsubscribe anytime.'
} = Astro.props;
---

<section class={`newsletter ${variant}`}>
  <div class="newsletter-inner">
    <h3>{title}</h3>
    {variant === 'default' && <p>{description}</p>}
    <form 
      class="newsletter-form" 
      action="https://buttondown.com/api/emails/embed-subscribe/nullbot" 
      method="post" 
      target="popupwindow" 
      onsubmit="window.open('https://buttondown.com/nullbot', 'popupwindow')"
    >
      <input 
        type="email" 
        name="email" 
        placeholder="your@email.com" 
        required 
        class="newsletter-input"
      />
      <button type="submit" class="newsletter-btn">Subscribe</button>
    </form>
    <span class="newsletter-note">Free forever. Unsubscribe in one click.</span>
  </div>
</section>

<style>
  .newsletter {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.08), rgba(236, 72, 153, 0.08));
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2.5rem 2rem;
    margin: 3rem 0;
    text-align: center;
  }

  .newsletter.compact {
    padding: 1.5rem 1.25rem;
    margin: 2rem 0;
  }

  .newsletter h3 {
    font-size: 1.4rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .newsletter.compact h3 {
    font-size: 1.1rem;
  }

  .newsletter p {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    max-width: 450px;
    margin: 0 auto 1.5rem;
  }

  .newsletter-form {
    display: flex;
    gap: 0.5rem;
    max-width: 420px;
    margin: 0 auto;
  }

  .newsletter-input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-card);
    color: var(--color-text);
    font-size: 0.95rem;
    transition: border-color 0.2s;
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
  }

  .newsletter-btn {
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, var(--color-accent), #9333ea);
    color: white;
    border: none;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .newsletter-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3);
  }

  .newsletter-note {
    display: block;
    margin-top: 0.75rem;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 480px) {
    .newsletter-form {
      flex-direction: column;
    }
    .newsletter-btn {
      padding: 0.85rem;
    }
  }
</style>
