---
import BaseLayout from '../../layouts/BaseLayout.astro';
import tools from '../../data/tools.json';

const toolsJson = JSON.stringify(tools);
---

<BaseLayout title="Compare AI Tools" description="Select AI tools to compare side-by-side. Pricing, features, pros, cons — all in one view.">
  <section class="hero">
    <div class="container">
      <h1>Compare <span class="gradient-text">AI Tools</span></h1>
      <p>Select up to 4 tools to compare side-by-side.</p>
    </div>
  </section>

  <section class="section-glow">
    <div class="container">
      <!-- Selector -->
      <div class="selector-bar">
        <div class="search-wrap">
          <input type="text" id="tool-search" placeholder="🔍 Search tools..." class="search-input" autocomplete="off" />
          <div class="suggestions" id="suggestions"></div>
        </div>
        <div class="chips" id="chips"></div>
      </div>

      <!-- Comparison -->
      <div class="compare-area hidden" id="compare-area">
        <div class="compare-controls">
          <span class="compare-count" id="compare-count"></span>
          <button class="clear-btn" id="clear-btn">Clear all</button>
        </div>
        <div class="table-scroll">
          <table class="compare-table" id="compare-table"></table>
        </div>
      </div>

      <div class="empty-state" id="empty-state">
        <p>Search and select 2 or more tools above to start comparing.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .selector-bar {
    margin-bottom: 2rem;
  }

  .search-wrap {
    position: relative;
    margin-bottom: 0.75rem;
  }

  .search-input {
    width: 100%;
    padding: 0.85rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
    color: var(--color-text);
    font-size: 0.95rem;
    font-family: var(--font-sans);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .search-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
  }

  .suggestions {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-top: none;
    border-radius: 0 0 var(--radius) var(--radius);
    max-height: 280px;
    overflow-y: auto;
    z-index: 50;
    display: none;
  }

  .suggestions.open { display: block; }

  .sug-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.7rem 1.25rem;
    cursor: pointer;
    transition: background 0.15s;
    font-size: 0.9rem;
  }

  .sug-item + .sug-item { border-top: 1px solid var(--color-border); }
  .sug-item:hover { background: var(--color-accent-light); }

  .sug-name { font-weight: 600; }
  .sug-meta { color: var(--color-text-secondary); font-size: 0.8rem; }

  /* Chips */
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.8rem;
    background: var(--color-accent-light);
    color: var(--color-accent);
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .chip-x {
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    opacity: 0.6;
    background: none;
    border: none;
    color: var(--color-accent);
    padding: 0;
    transition: opacity 0.15s;
  }

  .chip-x:hover { opacity: 1; }

  /* Compare area */
  .compare-area.hidden { display: none; }
  .empty-state { text-align: center; color: var(--color-text-secondary); padding: 2rem 0; }
  .empty-state.hidden { display: none; }

  .compare-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .compare-count {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .clear-btn {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.4rem 0.9rem;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    font-family: var(--font-sans);
    transition: all 0.2s;
  }

  .clear-btn:hover { border-color: #ef4444; color: #ef4444; }

  .table-scroll {
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
  }

  /* Table */
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .compare-table th,
  .compare-table td {
    padding: 0.8rem 1.25rem;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }

  .compare-table thead th {
    background: var(--color-bg-secondary);
    border-bottom: 2px solid var(--color-border);
    font-weight: 700;
    font-size: 1rem;
    position: sticky;
    top: 0;
    z-index: 2;
  }

  .compare-table thead th:first-child {
    position: sticky;
    left: 0;
    z-index: 3;
  }

  .compare-table tbody th {
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-secondary);
    background: var(--color-bg);
    width: 110px;
    white-space: nowrap;
    position: sticky;
    left: 0;
    z-index: 1;
  }

  .compare-table tbody tr:last-child th,
  .compare-table tbody tr:last-child td {
    border-bottom: none;
  }

  .tool-link {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 700;
    transition: color 0.2s;
  }

  .tool-link:hover { color: var(--color-accent); }

  .badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 20px;
    margin-top: 0.25rem;
  }

  .badge.free { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
  .badge.freemium { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
  .badge.paid { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
  .badge.pay-per-use { background: rgba(168, 85, 247, 0.15); color: #a855f7; }

  .compare-table td ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .compare-table td li {
    padding: 0.15rem 0;
    line-height: 1.4;
  }

  .pro::before { content: '✓ '; color: #22c55e; font-weight: 700; }
  .con::before { content: '✗ '; color: #ef4444; font-weight: 700; }

  .best-for {
    font-weight: 600;
    color: var(--color-accent);
  }

  .tag-pill {
    display: inline-block;
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    font-size: 0.72rem;
    margin: 0.1rem 0.15rem 0.1rem 0;
  }

  .visit-btn {
    display: inline-block;
    background: linear-gradient(135deg, var(--color-accent), #ec4899);
    color: white !important;
    padding: 0.5rem 1.2rem;
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.8rem;
    text-decoration: none;
    transition: all 0.3s;
    box-shadow: 0 2px 10px rgba(124, 58, 237, 0.3);
  }

  .visit-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 15px rgba(124, 58, 237, 0.4);
  }

  .review-link {
    display: block;
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-top: 0.4rem;
  }

  .review-link:hover { color: var(--color-accent); }

  @media (max-width: 768px) {
    .compare-table tbody th { font-size: 0.7rem; width: 80px; }
    .compare-table th, .compare-table td { padding: 0.5rem 0.75rem; font-size: 0.8rem; }
  }
</style>

<script define:vars={{ toolsJson }}>
  var allTools = JSON.parse(toolsJson);
  var picked = [];
  var MAX = 4;

  var searchEl = document.getElementById('tool-search');
  var sugEl = document.getElementById('suggestions');
  var chipsEl = document.getElementById('chips');
  var areaEl = document.getElementById('compare-area');
  var tableEl = document.getElementById('compare-table');
  var countEl = document.getElementById('compare-count');
  var emptyEl = document.getElementById('empty-state');
  var clearEl = document.getElementById('clear-btn');

  // Show all tools on focus, filter on type
  searchEl.addEventListener('focus', function() { renderSugs(searchEl.value); });
  searchEl.addEventListener('input', function() { renderSugs(this.value); });

  document.addEventListener('click', function(e) {
    if (!e.target.closest('.search-wrap')) sugEl.classList.remove('open');
  });

  function renderSugs(q) {
    var query = (q || '').toLowerCase();
    var items = allTools
      .filter(function(t) { return picked.indexOf(t.slug) === -1; })
      .filter(function(t) {
        if (!query) return true;
        return t.name.toLowerCase().indexOf(query) > -1 ||
               t.category.toLowerCase().indexOf(query) > -1 ||
               (t.tags || []).some(function(tag) { return tag.toLowerCase().indexOf(query) > -1; });
      })
      .slice(0, 15);

    if (items.length === 0) { sugEl.classList.remove('open'); return; }

    sugEl.innerHTML = items.map(function(t) {
      return '<div class="sug-item" data-slug="' + t.slug + '">' +
        '<span class="sug-name">' + t.name + '</span>' +
        '<span class="sug-meta">' + t.category + ' · ' + t.pricing + ' · ' + t.price + '</span>' +
      '</div>';
    }).join('');
    sugEl.classList.add('open');

    sugEl.querySelectorAll('.sug-item').forEach(function(el) {
      el.addEventListener('click', function() {
        if (picked.length < MAX) {
          picked.push(el.dataset.slug);
          searchEl.value = '';
          sugEl.classList.remove('open');
          render();
        }
      });
    });
  }

  function remove(slug) {
    picked = picked.filter(function(s) { return s !== slug; });
    render();
  }

  clearEl.addEventListener('click', function() {
    picked = [];
    render();
  });

  function render() {
    // Chips
    chipsEl.innerHTML = picked.map(function(slug) {
      var t = allTools.find(function(x) { return x.slug === slug; });
      return '<span class="chip">' + t.name +
        '<button class="chip-x" data-s="' + slug + '">×</button></span>';
    }).join('');
    chipsEl.querySelectorAll('.chip-x').forEach(function(btn) {
      btn.addEventListener('click', function() { remove(btn.dataset.s); });
    });

    // Toggle views
    if (picked.length < 2) {
      areaEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
      return;
    }

    emptyEl.classList.add('hidden');
    areaEl.classList.remove('hidden');
    countEl.textContent = picked.length + ' tools compared';

    buildTable();
  }

  function buildTable() {
    var tools = picked.map(function(s) { return allTools.find(function(t) { return t.slug === s; }); });

    // Header
    var h = '<thead><tr><th></th>';
    tools.forEach(function(t) {
      var cls = (t.pricing || '').toLowerCase().replace(/\s+/g, '-');
      h += '<th>' +
        '<a class="tool-link" href="/tools/' + t.slug + '/">' + t.name + '</a>' +
        '<div class="badge ' + cls + '">' + t.pricing + '</div>' +
      '</th>';
    });
    h += '</tr></thead><tbody>';

    // Rows
    var defs = [
      { label: 'Price', fn: function(t) { return t.price || t.pricing; } },
      { label: 'Category', fn: function(t) { return t.category; } },
      { label: 'Released', fn: function(t) { return t.released || '—'; } },
      { label: 'Best For', fn: function(t) { return '<span class="best-for">' + (t.bestFor || '—') + '</span>'; }, html: true },
      { label: 'Pros', fn: function(t) {
        return '<ul>' + (t.pros || []).map(function(p) { return '<li class="pro">' + p + '</li>'; }).join('') + '</ul>';
      }, html: true },
      { label: 'Cons', fn: function(t) {
        return '<ul>' + (t.cons || []).map(function(c) { return '<li class="con">' + c + '</li>'; }).join('') + '</ul>';
      }, html: true },
      { label: 'Tags', fn: function(t) {
        return (t.tags || []).map(function(tag) { return '<span class="tag-pill">' + tag + '</span>'; }).join('');
      }, html: true },
      { label: 'Links', fn: function(t) {
        return '<a class="visit-btn" href="' + (t.affiliateUrl || t.url) + '" target="_blank" rel="noopener">Visit ↗</a>' +
          '<a class="review-link" href="/tools/' + t.slug + '/">Read review →</a>';
      }, html: true },
    ];

    defs.forEach(function(row) {
      h += '<tr><th>' + row.label + '</th>';
      tools.forEach(function(t) {
        h += '<td>' + row.fn(t) + '</td>';
      });
      h += '</tr>';
    });

    h += '</tbody>';
    tableEl.innerHTML = h;
  }

  // Initial state
  render();
</script>
