---
import BaseLayout from '../../layouts/BaseLayout.astro';
import tools from '../../data/tools.json';

const toolsJson = JSON.stringify(tools);
---

<BaseLayout title="Compare AI Tools" description="Pick two AI tools and see how they stack up.">
  <section class="hero">
    <div class="container">
      <h1>Compare <span class="gradient-text">AI Tools</span></h1>
      <p>Pick two tools. See everything side by side.</p>
    </div>
  </section>

  <section class="section-glow">
    <div class="container">
      <div id="picker">
        <input type="text" id="filter" placeholder="Search tools..." class="search-bar" autocomplete="off" />
        <div class="tool-scroll">
          <div class="tool-list" id="tool-list"></div>
        </div>
        <div class="picker-action hidden" id="picker-action">
          <button class="go-btn" id="go-btn">Compare →</button>
        </div>
      </div>

      <div class="results hidden" id="results">
        <div class="results-top">
          <button class="back-btn" id="back-btn">← Pick different tools</button>
        </div>
        <div class="card-grid" id="result-cards"></div>
        <div class="detail-wrap">
          <table class="detail-table" id="detail-table"></table>
        </div>
      </div>
    </div>
  </section>

  <script id="tools-data" type="application/json" set:html={toolsJson} />
  <script>
    (function() {
      var tools = JSON.parse(document.getElementById('tools-data').textContent);
      tools.sort(function(a, b) { return a.name.localeCompare(b.name); });
      var picked = [];
      var MAX = 2;

      var filterEl = document.getElementById('filter');
      var listEl = document.getElementById('tool-list');
      var actionEl = document.getElementById('picker-action');
      var goBtn = document.getElementById('go-btn');
      var pickerEl = document.getElementById('picker');
      var resultsEl = document.getElementById('results');
      var backBtn = document.getElementById('back-btn');
      var cardsEl = document.getElementById('result-cards');
      var tableEl = document.getElementById('detail-table');

      function render() {
        var q = (filterEl.value || '').toLowerCase();
        var filtered = tools.filter(function(t) {
          if (!q) return true;
          return t.name.toLowerCase().indexOf(q) > -1 ||
                 t.category.toLowerCase().indexOf(q) > -1 ||
                 (t.tags || []).some(function(tag) { return tag.toLowerCase().indexOf(q) > -1; });
        });

        listEl.innerHTML = filtered.map(function(t) {
          var on = picked.indexOf(t.slug) > -1;
          var full = picked.length >= MAX && !on;
          var cls = on ? ' selected' : (full ? ' disabled' : '');
          return '<div class="tool-row' + cls + '" data-slug="' + t.slug + '">' + t.name + '</div>';
        }).join('');

        actionEl.classList.toggle('hidden', picked.length < 2);
      }

      listEl.addEventListener('click', function(e) {
        var row = e.target.closest('.tool-row');
        if (!row || row.classList.contains('disabled')) return;
        var slug = row.dataset.slug;
        var idx = picked.indexOf(slug);
        if (idx > -1) {
          picked.splice(idx, 1);
        } else if (picked.length < MAX) {
          picked.push(slug);
        }
        render();
      });

      filterEl.addEventListener('input', render);

      goBtn.addEventListener('click', function() {
        if (picked.length < 2) return;
        pickerEl.classList.add('hidden');
        resultsEl.classList.remove('hidden');
        var ts = picked.map(function(s) { return tools.find(function(t) { return t.slug === s; }); });

        cardsEl.innerHTML = ts.map(function(t, i) {
          return '<a href="/tools/' + t.slug + '/" class="card" style="text-decoration: none; color: inherit; animation: cardFadeIn 0.45s ease ' + (i * 0.08) + 's forwards;">' +
            '<h3>' + t.name + '</h3>' +
            '<p>' + t.description + '</p>' +
            '<span class="tag">' + t.category + '</span>' +
            '<span class="tag">' + t.pricing + '</span>' +
            '<span class="tag">' + t.price + '</span>' +
          '</a>';
        }).join('');

        var h = '<thead><tr><th></th>';
        ts.forEach(function(t) {
          h += '<th><a href="/tools/' + t.slug + '/">' + t.name + '</a></th>';
        });
        h += '</tr></thead><tbody>';

        var rows = [
          { label: 'Price', fn: function(t) { return t.price || t.pricing; } },
          { label: 'Category', fn: function(t) { return t.category; } },
          { label: 'Released', fn: function(t) { return t.released || '—'; } },
          { label: 'Best For', fn: function(t) { return '<span class="val-accent">' + (t.bestFor || '—') + '</span>'; } },
          { label: 'Pros', fn: function(t) {
            return '<ul>' + (t.pros || []).map(function(p) { return '<li class="pro">' + p + '</li>'; }).join('') + '</ul>';
          }},
          { label: 'Cons', fn: function(t) {
            return '<ul>' + (t.cons || []).map(function(c) { return '<li class="con">' + c + '</li>'; }).join('') + '</ul>';
          }},
          { label: 'Tags', fn: function(t) {
            return '<span class="cell-tags">' + (t.tags || []).map(function(tag) { return '<span>' + tag + '</span>'; }).join('') + '</span>';
          }},
          { label: '', fn: function(t) {
            return '<a class="visit-link" href="' + (t.affiliateUrl || t.url) + '" target="_blank" rel="noopener">Visit ↗</a>' +
              '<a class="rev-link" href="/tools/' + t.slug + '/">Read review →</a>';
          }},
        ];

        rows.forEach(function(row) {
          h += '<tr><th>' + row.label + '</th>';
          ts.forEach(function(t) { h += '<td>' + row.fn(t) + '</td>'; });
          h += '</tr>';
        });

        h += '</tbody>';
        tableEl.innerHTML = h;

        resultsEl.scrollIntoView({ behavior: 'smooth' });
      });

      backBtn.addEventListener('click', function() {
        resultsEl.classList.add('hidden');
        pickerEl.classList.remove('hidden');
        render();
      });

      render();
    })();
  </script>
</BaseLayout>

<style>
  .search-bar {
    width: 100%;
    padding: 0.9rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg-card);
    color: var(--color-text);
    font-size: 1rem;
    font-family: var(--font-sans);
    transition: border-color 0.2s, box-shadow 0.2s;
    margin-bottom: 1rem;
  }

  .search-bar:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.08);
  }

  .tool-scroll {
    max-height: 560px;
    overflow-y: auto;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg-card);
  }

  .tool-scroll::-webkit-scrollbar { width: 5px; }
  .tool-scroll::-webkit-scrollbar-track { background: transparent; }
  .tool-scroll::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 3px; }

  .tool-list { padding: 0.25rem; }

  .tool-row {
    padding: 0.75rem 1rem;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.15s, opacity 0.15s;
    user-select: none;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .tool-row:not(.selected):not(.disabled):hover {
    background: var(--color-bg-secondary);
  }

  .tool-row.selected {
    background: var(--color-accent);
    color: white;
  }

  .tool-row.disabled {
    opacity: 0.3;
    cursor: default;
  }

  .picker-action { text-align: center; margin-top: 1.5rem; }
  .picker-action.hidden { display: none; }

  .go-btn {
    background: linear-gradient(135deg, var(--color-accent), #ec4899);
    color: white;
    border: none;
    border-radius: 50px;
    padding: 0.8rem 2.5rem;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 4px 15px rgba(124, 58, 237, 0.25);
    font-family: var(--font-sans);
  }

  .go-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(124, 58, 237, 0.35); }

  .results.hidden { display: none; }
  .results-top { display: flex; justify-content: flex-end; margin-bottom: 1rem; }

  .back-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    font-family: var(--font-sans);
    transition: opacity 0.2s;
    padding: 0;
  }

  .back-btn:hover { opacity: 0.7; }

  .detail-wrap {
    margin-top: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    background: var(--color-bg-card);
  }

  .detail-table { width: 100%; border-collapse: collapse; }

  .detail-table th,
  .detail-table td {
    padding: 1rem 1.5rem;
    text-align: left;
    vertical-align: top;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .detail-table tbody tr {
    border-top: 2px solid var(--color-border);
  }

  .detail-table tbody th {
    font-weight: 600;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    width: 120px;
    white-space: nowrap;
    background: var(--color-bg);
    padding-left: 1.5rem;
  }

  .detail-table thead th {
    background: var(--color-bg);
    font-weight: 700;
    font-size: 1.05rem;
    padding: 1.25rem 1.5rem;
    border-bottom: 2px solid var(--color-border);
  }

  .detail-table thead a { color: var(--color-text); text-decoration: none; transition: color 0.2s; }
  .detail-table thead a:hover { color: var(--color-accent); }

  .detail-table td ul { list-style: none; padding: 0; margin: 0; }
  .detail-table td li { padding: 0.2rem 0; line-height: 1.5; }
  .pro::before { content: '✓ '; color: #22c55e; font-weight: 700; }
  .con::before { content: '✗ '; color: #ef4444; font-weight: 700; }
  .val-accent { color: var(--color-accent); font-weight: 600; }

  .cell-tags span {
    display: inline-block;
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    font-size: 0.72rem;
    margin: 0.1rem;
  }

  .visit-link {
    display: inline-block;
    background: linear-gradient(135deg, var(--color-accent), #ec4899);
    color: white !important;
    padding: 0.5rem 1.2rem;
    border-radius: 50px;
    font-weight: 700;
    font-size: 0.8rem;
    text-decoration: none;
    transition: all 0.3s;
    box-shadow: 0 2px 8px rgba(124, 58, 237, 0.25);
  }

  .visit-link:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(124, 58, 237, 0.35); }

  .rev-link {
    display: block;
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-top: 0.5rem;
  }

  .rev-link:hover { color: var(--color-accent); }

  @media (max-width: 768px) {
    .tool-scroll { max-height: 400px; }
    .detail-table th, .detail-table td { padding: 0.7rem 1rem; font-size: 0.82rem; }
    .detail-table tbody th { width: 90px; font-size: 0.72rem; padding-left: 1rem; }
  }
</style>
