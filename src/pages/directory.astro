---
import BaseLayout from '../layouts/BaseLayout.astro';
import tools from '../data/tools.json';

const categories = [...new Set(tools.map(t => t.category))].sort();
const pricingOptions = [...new Set(tools.map(t => t.pricing))].sort();
---

<BaseLayout title="AI Tools Directory" description="Browse 30+ curated AI tools for solopreneurs and freelancers. Filter by category, pricing, and find the perfect tool for your workflow.">
  <section class="hero">
    <div class="container">
      <h1>AI Tools <span class="gradient-text">Directory</span></h1>
      <p>{tools.length} curated AI tools and agents for solopreneurs. Filter by category, pricing, or search by name.</p>
    </div>
  </section>

  <section class="container">
    <!-- Filters -->
    <div class="directory-filters">
      <input 
        type="text" 
        id="search" 
        placeholder="🔍 Search tools..." 
        class="filter-search"
      />
      <div class="filter-group">
        <select id="category-filter" class="filter-select">
          <option value="">All Categories</option>
          {categories.map(cat => (
            <option value={cat}>{cat}</option>
          ))}
        </select>
        <select id="pricing-filter" class="filter-select">
          <option value="">All Pricing</option>
          {pricingOptions.map(price => (
            <option value={price}>{price}</option>
          ))}
        </select>
        <select id="sort" class="filter-select">
          <option value="name">Sort: A-Z</option>
          <option value="name-desc">Sort: Z-A</option>
          <option value="newest">Sort: Newest</option>
          <option value="oldest">Sort: Oldest</option>
        </select>
      </div>
    </div>

    <!-- Tools Grid -->
    <div class="tools-grid" id="tools-grid">
      {tools.map((tool) => (
        <div class="tool-card" data-category={tool.category} data-pricing={tool.pricing} data-name={tool.name.toLowerCase()} data-tags={tool.tags.join(',')} data-added={tool.added}>
          <div class="tool-card-header">
            <h3><a href={`/tools/${tool.slug}/`}>{tool.name}</a></h3>
            <span class={`pricing-badge ${tool.pricing.toLowerCase()}`}>{tool.pricing}</span>
          </div>
          <p class="tool-description">{tool.description}</p>
          <div class="tool-meta">
            <span class="tool-category">{tool.category}</span>
            <span class="tool-released">{tool.released}</span>
          </div>
          <div class="tool-tags">
            {tool.tags.slice(0, 3).map(tag => (
              <span class="tool-tag">{tag}</span>
            ))}
          </div>
          <div class="tool-card-actions">
            <a href={`/tools/${tool.slug}/`} class="tool-link-details">Details →</a>
            <a href={tool.affiliateUrl || tool.url} target="_blank" rel="noopener" class="tool-link-visit">Visit Site ↗</a>
          </div>
        </div>
      ))}
    </div>

    <p class="no-results" id="no-results" style="display: none; text-align: center; color: var(--color-text-secondary); padding: 3rem 0;">
      No tools found matching your filters. Try a different search.
    </p>

    <p class="tool-count" id="tool-count" style="text-align: center; color: var(--color-text-secondary); margin-top: 2rem;">
      Showing {tools.length} tools
    </p>
  </section>
</BaseLayout>

<style>
  .directory-filters {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .filter-search {
    flex: 1;
    min-width: 200px;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
    color: var(--color-text);
    font-size: 0.95rem;
    transition: border-color 0.2s;
  }

  .filter-search:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .filter-group {
    display: flex;
    gap: 0.5rem;
  }

  .filter-select {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
    color: var(--color-text);
    font-size: 0.9rem;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .filter-select:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .tool-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tool-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .tool-card.hidden {
    display: none;
  }

  .tool-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .tool-card-header h3 {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .tool-card-header a {
    color: var(--color-text);
    transition: color 0.2s;
  }

  .tool-card-header a:hover {
    color: var(--color-accent);
  }

  .pricing-badge {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 20px;
    white-space: nowrap;
  }

  .pricing-badge.free { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
  .pricing-badge.freemium { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
  .pricing-badge.paid { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }

  .tool-description {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .tool-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .tool-category {
    font-weight: 600;
    color: var(--color-accent);
  }

  .tool-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tool-tag {
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.7rem;
  }

  .tool-card-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }

  .tool-link-details {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    transition: all 0.2s;
  }

  .tool-link-details:hover {
    transform: translateX(4px);
  }

  .tool-link-visit {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    background: var(--color-bg-secondary);
    padding: 0.3rem 0.75rem;
    border-radius: 6px;
    transition: all 0.2s;
  }

  .tool-link-visit:hover {
    background: var(--color-accent);
    color: white;
  }

  @media (max-width: 768px) {
    .directory-filters { flex-direction: column; }
    .filter-group { flex-direction: column; }
    .tools-grid { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  const searchInput = document.getElementById('search');
  const categoryFilter = document.getElementById('category-filter');
  const pricingFilter = document.getElementById('pricing-filter');
  const sortSelect = document.getElementById('sort');
  const toolsGrid = document.getElementById('tools-grid');
  const noResults = document.getElementById('no-results');
  const toolCount = document.getElementById('tool-count');

  function filterAndSort() {
    const search = searchInput.value.toLowerCase();
    const category = categoryFilter.value;
    const pricing = pricingFilter.value;
    const sort = sortSelect.value;
    const cards = Array.from(toolsGrid.querySelectorAll('.tool-card'));
    let visible = 0;

    // Filter
    cards.forEach(card => {
      const name = card.dataset.name;
      const tags = card.dataset.tags;
      const cardCategory = card.dataset.category;
      const cardPricing = card.dataset.pricing;

      const matchesSearch = !search || name.includes(search) || tags.includes(search);
      const matchesCategory = !category || cardCategory === category;
      const matchesPricing = !pricing || cardPricing === pricing;

      if (matchesSearch && matchesCategory && matchesPricing) {
        card.classList.remove('hidden');
        visible++;
      } else {
        card.classList.add('hidden');
      }
    });

    // Sort
    const visibleCards = cards.filter(c => !c.classList.contains('hidden'));
    visibleCards.sort((a, b) => {
      switch(sort) {
        case 'name': return a.dataset.name.localeCompare(b.dataset.name);
        case 'name-desc': return b.dataset.name.localeCompare(a.dataset.name);
        case 'newest': return (b.dataset.added || '').localeCompare(a.dataset.added || '');
        case 'oldest': return (a.dataset.added || '').localeCompare(b.dataset.added || '');
        default: return 0;
      }
    });
    visibleCards.forEach(card => toolsGrid.appendChild(card));

    noResults.style.display = visible === 0 ? 'block' : 'none';
    toolCount.textContent = `Showing ${visible} tool${visible !== 1 ? 's' : ''}`;
  }

  searchInput.addEventListener('input', filterAndSort);
  categoryFilter.addEventListener('change', filterAndSort);
  pricingFilter.addEventListener('change', filterAndSort);
  sortSelect.addEventListener('change', filterAndSort);
</script>
