---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const tutorials = (await getCollection('tutorials'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Tutorials" description="Step-by-step tutorials for AI tools, agents, and automation workflows.">
  <section class="hero">
    <div class="container">
      <h1><span class="gradient-text">Tutorials</span></h1>
      <p>Step-by-step guides to set up and use AI tools. Practical, tested, beginner-friendly.</p>
    </div>
  </section>
  
  <section class="section-glow">
    <div class="container">
      <input 
        type="text" 
        id="tutorial-search" 
        placeholder="🔍 Search tutorials..." 
        class="blog-search"
      />

      <div class="card-grid" id="tutorial-grid">
        {tutorials.map((post) => (
          <a href={`/tutorials/${post.id.replace(/\.md$/, '')}/`} class="card tutorial-card" data-title={post.data.title.toLowerCase()} data-desc={post.data.description.toLowerCase()} data-tool={post.data.toolName.toLowerCase()} style="text-decoration: none; color: inherit;">
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.5rem;">
              <span class="tag">{post.data.toolName}</span>
              <span class="tag">{post.data.difficulty}</span>
              {post.data.timeToComplete && <span class="tag">⏱️ {post.data.timeToComplete}</span>}
            </div>
          </a>
        ))}
      </div>

      <p class="no-results" id="no-results" style="display: none; text-align: center; color: var(--color-text-secondary); padding: 3rem 0;">
        No tutorials found matching your search.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-search {
    width: 100%;
    padding: 0.85rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
    color: var(--color-text);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    transition: border-color 0.2s;
  }

  .blog-search:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
  }
</style>

  <style>
    .card {
      opacity: 0;
      transform: translateY(30px) scale(0.97);
    }

    .card.animate-in {
      animation: cardIn 0.7s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
    }

    @keyframes cardIn {
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
  </style>

<script is:inline>
  const searchInput = document.getElementById('tutorial-search');
  const grid = document.getElementById('tutorial-grid');
  const noResults = document.getElementById('no-results');

  searchInput.addEventListener('input', () => {
    const search = searchInput.value.toLowerCase();
    const cards = grid.querySelectorAll('.tutorial-card');
    let visible = 0;

    cards.forEach(card => {
      const title = card.dataset.title;
      const desc = card.dataset.desc;
      const tool = card.dataset.tool;
      
      if (!search || title.includes(search) || desc.includes(search) || tool.includes(search)) {
        card.style.display = '';
        visible++;
      } else {
        card.style.display = 'none';
      }
    });

    noResults.style.display = visible === 0 ? 'block' : 'none';
  });

  // Scroll animation observer
  const scrollObserver = new IntersectionObserver((entries) => {
    const visible = entries.filter(e => e.isIntersecting).sort((a, b) => {
      return a.boundingClientRect.top - b.boundingClientRect.top;
    });
    visible.forEach((entry, i) => {
      entry.target.style.animationDelay = `${i * 100}ms`;
      entry.target.classList.add('animate-in');
      scrollObserver.unobserve(entry.target);
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

  document.querySelectorAll('.card').forEach(card => {
    scrollObserver.observe(card);
  });
</script>
