---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import tools from '../../data/tools.json';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorials');
  return tutorials.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Find the tool in our database
const tool = tools.find(t => t.name.toLowerCase() === post.data.toolName.toLowerCase() || t.slug === post.data.toolName.toLowerCase().replace(/\s+/g, '-'));
---

<ArticleLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
>
  <div class="tutorial-meta-box">
    <div class="tutorial-meta-item">
      <span class="meta-label">Tool</span>
      <span class="meta-value">{post.data.toolName}</span>
    </div>
    <div class="tutorial-meta-item">
      <span class="meta-label">Difficulty</span>
      <span class="meta-value">{post.data.difficulty}</span>
    </div>
    {post.data.timeToComplete && (
      <div class="tutorial-meta-item">
        <span class="meta-label">Time</span>
        <span class="meta-value">⏱️ {post.data.timeToComplete}</span>
      </div>
    )}
  </div>

  {tool && (
    <div class="tool-links-box">
      <strong>📚 {post.data.toolName} Links:</strong>
      <a href={tool.affiliateUrl || tool.url} target="_blank" rel="noopener">Website</a>
      <span class="link-sep">·</span>
      <a href={`/tools/${tool.slug}/`}>Our Review</a>
      {(() => {
        const docsUrls = {
          'n8n': 'https://docs.n8n.io/',
          'openclaw': 'https://docs.openclaw.ai/',
        };
        const docsUrl = docsUrls[tool.slug] || `${tool.url}/docs`;
        return <><span class="link-sep">·</span><a href={docsUrl} target="_blank" rel="noopener">Docs</a></>;
      })()}
    </div>
  )}
  
  <Content />
</ArticleLayout>

<style>
  .tutorial-meta-box {
    display: flex;
    gap: 1.5rem;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem 1.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .tutorial-meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .meta-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
  }

  .meta-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .tool-links-box {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.85rem 1.25rem;
    margin-bottom: 2rem;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tool-links-box a {
    font-weight: 600;
  }

  .link-sep {
    color: var(--color-text-secondary);
  }
</style>
