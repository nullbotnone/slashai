---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const guides = (await getCollection('guides'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Workflow Guides" description="Step-by-step tutorials on AI-powered workflows for freelancers.">
  <section class="hero">
    <div class="container">
      <h1>Workflow Guides</h1>
      <p>Step-by-step tutorials on setting up AI-powered workflows that save hours every week.</p>
    </div>
  </section>
  
  <section class="container">
    <div class="card-grid">
      {guides.map((post) => (
        <a href={`/guides/${post.slug}/`} class="card" style="text-decoration: none; color: inherit;">
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
