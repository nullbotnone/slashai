---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="hero">
    <div class="container">
      <h1 class="error-code">404</h1>
      <p>That page doesn't exist — or it got automated away by an AI agent.</p>
    </div>
  </section>

  <div class="article-content" style="text-align: center;">
    <p>Here are some places that <em>do</em> exist:</p>
    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin: 2rem 0;">
      <a href="/" class="card" style="text-decoration: none; color: inherit; display: inline-block; padding: 1rem 1.5rem;">
        <h3>🏠 Home</h3>
      </a>
      <a href="/ai-tools/" class="card" style="text-decoration: none; color: inherit; display: inline-block; padding: 1rem 1.5rem;">
        <h3>🛠️ AI Tools</h3>
      </a>
      <a href="/blog/" class="card" style="text-decoration: none; color: inherit; display: inline-block; padding: 1rem 1.5rem;">
        <h3>📝 Blog</h3>
      </a>
      <a href="/roundups/best-ai-tools-freelancers/" class="card" style="text-decoration: none; color: inherit; display: inline-block; padding: 1rem 1.5rem;">
        <h3>📊 Best AI Tools</h3>
      </a>
    </div>

    <NewsletterCTA 
      title="While you're here..."
      description="Get weekly AI tool picks and workflow tips for solopreneurs."
    />
  </div>
</BaseLayout>

<style>
  .error-code {
    font-size: 6rem;
    font-weight: 900;
    background: linear-gradient(135deg, var(--color-accent), #ec4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: 1rem;
  }
</style>
