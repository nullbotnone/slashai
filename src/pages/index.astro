---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import toolsData from '../data/tools.json';

const allReviews = await getCollection('reviews');
const allRoundups = await getCollection('roundups');
const allComparisons = await getCollection('comparisons');
const allAgents = await getCollection('agents');

const recentPosts = [...allReviews, ...allRoundups, ...allComparisons, ...allAgents]
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

// Featured/trending tools for homepage
const trendingTools = toolsData.filter((t) => t.featured).slice(0, 6);

const categories = [
  {
    href: '/ai-tools/',
    title: 'AI Tools Database',
    description: '45+ curated tools and agents with pricing, features, and direct links.',
  },
  {
    href: '/blog/',
    title: 'Blog',
    description: 'Reviews, comparisons, roundups, and workflow guides — tested on real freelance work.',
  },
  {
    href: '/agents/',
    title: 'AI Agents',
    description: 'Autonomous agents that handle email, research, and workflows while you sleep.',
  },
  {
    href: '/roundups/',
    title: 'Best-Of Roundups',
    description: 'Curated lists for every freelancer need — writing, design, productivity, and more.',
  },
  {
    href: '/build-your-stack/',
    title: 'Build Your Stack',
    description: 'Pick your role and budget. Get a personalized AI toolkit recommended for your business.',
  },
  {
    href: '/compare/',
    title: 'Compare Tools',
    description: 'Side-by-side breakdowns — pricing, features, pros, and cons of any two AI tools.',
  },
  {
    href: '/tutorials/',
    title: 'Tutorials',
    description: 'Step-by-step setup guides. Practical, tested, beginner-friendly.',
  },
  {
    href: '/guides/',
    title: 'Workflow Guides',
    description: 'AI-powered workflows that save hours every week. Real setups you can copy.',
  },
];
---

<BaseLayout title="AI Tools for Solopreneurs & Freelancers">
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <span class="eyebrow">Tested on real freelance work</span>
      <h1>
        AI tools that actually work<br />
        <span class="accent">for one-person businesses.</span>
      </h1>
      <p>
        Honest reviews, practical guides, and real workflows. We test every tool so you don't
        waste time on the ones that don't deliver.
      </p>
      <div class="hero-actions">
        <a href="/ai-tools/" class="btn btn-primary">Browse the database →</a>
        <a href="/build-your-stack/" class="btn btn-secondary">Build your stack</a>
      </div>
    </div>
  </section>

  <!-- Trending tools -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">Featured</span>
          <h2>Trending AI tools</h2>
        </div>
        <a href="/ai-tools/" class="see-all">All {toolsData.length} tools →</a>
      </div>
      <div class="trending-grid">
        {trendingTools.map((tool) => (
          <a href={`/tools/${tool.slug}/`} class="tool-card">
            <div class="tool-card-head">
              <h3>{tool.name}</h3>
              <span class={`pricing-badge ${tool.pricing.toLowerCase()}`}>{tool.pricing}</span>
            </div>
            <p>{tool.description}</p>
            <span class="tool-card-foot">{tool.category}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest articles -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">Recent</span>
          <h2>Latest articles</h2>
        </div>
        <a href="/blog/" class="see-all">All articles →</a>
      </div>
      <div class="card-grid">
        {recentPosts.map((post) => {
          const slug = post.id.replace(/\.md$/, '');
          const collection = post.collection;
          const path = `/${collection}/${slug}/`;
          const tag =
            collection === 'reviews'
              ? 'Review'
              : collection === 'roundups'
              ? 'Roundup'
              : collection === 'comparisons'
              ? 'Comparison'
              : collection === 'agents'
              ? 'Agents'
              : 'Guide';
          return (
            <a href={path} class="card">
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <span class="tag">{tag}</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Browse -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <span class="section-eyebrow">Browse</span>
          <h2>Explore by category</h2>
        </div>
      </div>
      <div class="category-grid">
        {categories.map((c) => (
          <a href={c.href} class="category-card">
            <div class="category-card-body">
              <h3>{c.title}</h3>
              <p>{c.description}</p>
            </div>
            <span class="category-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-panel">
        <span class="section-eyebrow">The SlashAI stack</span>
        <h2>Start free. Upgrade when revenue justifies it.</h2>
        <p>
          Every tool we recommend is tested on real freelance work — no sponsored fluff,
          no untested hype.
        </p>
        <div class="cta-actions">
          <a href="/roundups/best-ai-tools-freelancers/" class="btn btn-primary">See the stack →</a>
          <a href="/about/" class="btn btn-ghost">How we test</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Trending tools */
  .trending-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.1rem 1.2rem 1.25rem;
    color: inherit;
    transition: border-color 0.2s var(--ease-out),
                transform 0.25s var(--ease-out),
                box-shadow 0.25s var(--ease-out);
    opacity: 0;
    transform: translateY(8px);
    animation: fadeUp 0.5s var(--ease-out) forwards;
  }

  .tool-card:nth-child(1) { animation-delay: 0.02s; }
  .tool-card:nth-child(2) { animation-delay: 0.05s; }
  .tool-card:nth-child(3) { animation-delay: 0.08s; }
  .tool-card:nth-child(4) { animation-delay: 0.11s; }
  .tool-card:nth-child(5) { animation-delay: 0.14s; }
  .tool-card:nth-child(6) { animation-delay: 0.17s; }

  .tool-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    color: inherit;
  }

  .tool-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  .tool-card-head h3 {
    font-size: 0.975rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .tool-card p {
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    line-height: 1.55;
    flex: 1;
  }

  .tool-card-foot {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-tertiary);
    margin-top: 0.4rem;
  }

  .pricing-badge {
    font-size: 0.65rem;
    font-weight: 500;
    padding: 0.18rem 0.5rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    background: var(--color-bg-subtle);
    white-space: nowrap;
    letter-spacing: 0.02em;
  }

  .pricing-badge.free {
    color: var(--color-success);
    border-color: color-mix(in srgb, var(--color-success) 22%, var(--color-border));
    background: color-mix(in srgb, var(--color-success) 6%, var(--color-bg-subtle));
  }

  /* Category grid */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .category-card {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1.15rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: inherit;
    transition: border-color 0.2s var(--ease-out),
                transform 0.25s var(--ease-out),
                background 0.2s var(--ease-out);
  }

  .category-card:hover {
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
    background: var(--color-surface-hover);
    color: inherit;
  }

  .category-card-body h3 {
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 0.2rem;
  }

  .category-card-body p {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .category-arrow {
    flex-shrink: 0;
    color: var(--color-text-tertiary);
    font-size: 0.95rem;
    margin-top: 0.1rem;
    transition: transform 0.25s var(--ease-out), color 0.2s var(--ease-out);
  }

  .category-card:hover .category-arrow {
    transform: translateX(3px);
    color: var(--color-text);
  }

  /* CTA panel */
  .cta-panel {
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 3rem 2rem;
    text-align: center;
  }

  .cta-panel .section-eyebrow {
    margin-bottom: 0.75rem;
  }

  .cta-panel h2 {
    font-size: clamp(1.5rem, 2.5vw, 1.875rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  .cta-panel p {
    color: var(--color-text-secondary);
    font-size: 0.975rem;
    max-width: 500px;
    margin: 0 auto 1.75rem;
    line-height: 1.6;
  }

  .cta-actions {
    display: inline-flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .trending-grid,
    .category-grid {
      grid-template-columns: 1fr;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .cta-panel {
      padding: 2.25rem 1.25rem;
    }
  }
</style>
