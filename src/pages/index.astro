---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import toolsData from '../data/tools.json';
import NewsletterCTA from '../components/NewsletterCTA.astro';

const allReviews = await getCollection('reviews');
const allRoundups = await getCollection('roundups');
const allComparisons = await getCollection('comparisons');
const allAgents = await getCollection('agents');

const recentPosts = [...allReviews, ...allRoundups, ...allComparisons, ...allAgents]
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

// Featured/trending tools for homepage
const trendingTools = toolsData.filter(t => t.featured).slice(0, 6);
---

<BaseLayout title="AI Tools for Solopreneurs & Freelancers">
  <section class="hero">
    <div class="container">
      <h1>AI tools that <span class="gradient-text">actually work</span><br>for one-person businesses</h1>
      <p>Honest reviews, practical guides, and real workflows. We test every tool so you don't have to waste time on ones that don't deliver.</p>
    </div>
  </section>

  <!-- Trending AI Tools -->
  <section class="container">
    <div class="section-header">
      <h2>Trending <span class="gradient-text">AI Tools</span></h2>
      <a href="/ai-tools/" class="see-all">See all {toolsData.length} tools →</a>
    </div>
    <div class="trending-grid">
      {trendingTools.map((tool) => (
        <a href={`/tools/${tool.slug}/`} class="trending-card">
          <div class="trending-card-top">
            <h3>{tool.name}</h3>
            <span class={`pricing-badge ${tool.pricing.toLowerCase()}`}>{tool.pricing}</span>
          </div>
          <p>{tool.description}</p>
          <span class="trending-category">{tool.category}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="container" style="margin-top: 3rem;">
    <h2 style="margin-bottom: 1rem; font-size: 1.3rem;">Latest Articles</h2>
    <div class="card-grid">
      {recentPosts.map((post) => {
        const slug = post.id.replace(/\.md$/, '');
        const collection = post.collection;
        const path = `/${collection}/${slug}/`;
        const tag = collection === 'reviews' ? 'Review' :
                    collection === 'roundups' ? 'Roundup' :
                    collection === 'comparisons' ? 'Comparison' :
                    collection === 'agents' ? 'AI Agents' : 'Guide';
        return (
          <a href={path} class="card" style="text-decoration: none; color: inherit;">
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            <span class="tag">{tag}</span>
          </a>
        );
      })}
    </div>
  </section>

  <section class="container" style="margin-top: 3rem;">
    <h2 style="margin-bottom: 1rem; font-size: 1.3rem;">Browse by Category</h2>
    <div class="card-grid">
      <a href="/ai-tools/" class="card" style="text-decoration: none; color: inherit;">
        <h3>🛠️ AI Tools Database</h3>
        <p>45+ curated tools & agents with pricing, features, and direct links. Filter by category and find your perfect stack.</p>
      </a>
      <a href="/blog/" class="card" style="text-decoration: none; color: inherit;">
        <h3>📝 Blog</h3>
        <p>Reviews, comparisons, roundups, and workflow guides. Honest takes tested on real freelance work.</p>
      </a>
      <a href="/agents/" class="card" style="text-decoration: none; color: inherit;">
        <h3>🤖 AI Agents</h3>
        <p>Autonomous agents that handle email, research, customer support, and workflows while you sleep.</p>
      </a>
      <a href="/roundups/" class="card" style="text-decoration: none; color: inherit;">
        <h3>📊 Best-Of Roundups</h3>
        <p>Curated lists of the best AI tools for every freelancer need — writing, design, productivity, and more.</p>
      </a>
    </div>
  </section>

  <div class="container">
    <NewsletterCTA />
  </div>

  <section class="container" style="margin-top: 1rem; text-align: center; padding: 3rem 0;">
    <h2 style="font-size: 1.5rem; margin-bottom: 0.75rem;">The Slash<span style="background: linear-gradient(135deg, var(--color-accent), #ec4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">AI</span> Stack</h2>
    <p style="color: var(--color-text-secondary); max-width: 500px; margin: 0 auto 1.5rem;">Start free. Upgrade when revenue justifies it. Every tool we recommend is tested on real freelance work.</p>
    <a href="/roundups/best-ai-tools-freelancers/" style="display: inline-block; background: linear-gradient(135deg, var(--color-accent), #ec4899); color: white; padding: 0.75rem 2rem; border-radius: 50px; font-weight: 600; transition: all 0.3s; box-shadow: 0 4px 15px rgba(124, 58, 237, 0.3);">
      See the Stack →
    </a>
  </section>
</BaseLayout>

<style>
  a[href*="best-ai-tools-freelancers"]:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(124, 58, 237, 0.4) !important;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    font-size: 1.3rem;
  }

  .see-all {
    font-size: 0.85rem;
    font-weight: 600;
  }

  .trending-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }

  .trending-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .trending-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 8px 25px rgba(124, 58, 237, 0.15);
  }

  .trending-card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .trending-card-top h3 {
    font-size: 1rem;
    font-weight: 700;
  }

  .trending-card p {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .trending-category {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .pricing-badge {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.15rem 0.4rem;
    border-radius: 20px;
    white-space: nowrap;
  }

  .pricing-badge.free { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
  .pricing-badge.freemium { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
  .pricing-badge.paid { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }

  @media (max-width: 768px) {
    .trending-grid { grid-template-columns: 1fr; }
    .section-header { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  }
</style>
yle>
