---
import BaseLayout from '../layouts/BaseLayout.astro';
import tools from '../data/tools.json';

const TOOLS_PER_PAGE = 12;
const totalPages = Math.ceil(tools.length / TOOLS_PER_PAGE);
const currentPage = 1;
const paginatedTools = tools.slice(0, TOOLS_PER_PAGE);

const categories = [...new Set(tools.map(t => t.category))].sort();
const pricingOptions = [...new Set(tools.map(t => t.pricing))].sort();
---

<BaseLayout title="AI Tools Database" description={`Browse ${tools.length}+ curated AI tools for solopreneurs and freelancers. Filter by category, pricing, and find the perfect tool.`}>
  <section class="hero">
    <div class="container">
      <h1>AI <span class="gradient-text">Tools</span></h1>
      <p>{tools.length} curated tools & agents for solopreneurs. Filter, search, and find your perfect stack.</p>
    </div>
  </section>

  <section class="section-glow">
    <div class="container">
      <!-- Filters -->
    <div class="directory-filters">
      <input 
        type="text" 
        id="search" 
        placeholder="🔍 Search tools..." 
        class="filter-search"
      />
      <div class="filter-group">
        <select id="category-filter" class="filter-select">
          <option value="">All Categories</option>
          {categories.map(cat => (
            <option value={cat}>{cat}</option>
          ))}
        </select>
        <select id="pricing-filter" class="filter-select">
          <option value="">All Pricing</option>
          {pricingOptions.map(price => (
            <option value={price}>{price}</option>
          ))}
        </select>
        <select id="sort" class="filter-select">
          <option value="name">A-Z</option>
          <option value="name-desc">Z-A</option>
          <option value="newest">Newest</option>
          <option value="oldest">Oldest</option>
        </select>
      </div>
    </div>

    <!-- Featured Tools (Page 1 only) -->
    <div class="featured-section" id="featured-section">
      <h2 style="font-size: 1.2rem; margin-bottom: 1rem;">⭐ Featured Tools</h2>
      <div class="tools-grid">
        {tools.filter(t => t.featured).map((tool) => (
          <div class="tool-card" data-category={tool.category} data-pricing={tool.pricing} data-name={tool.name.toLowerCase()} data-tags={tool.tags.join(',')} data-added={tool.added} data-featured="true" data-url={`/tools/${tool.slug}/`}>
            <div class="tool-card-header">
              <h3><a href={`/tools/${tool.slug}/`}>{tool.name}</a></h3>
              <span class={`pricing-badge ${tool.pricing.toLowerCase()}`}>{tool.pricing}</span>
            </div>
            <p class="tool-description">{tool.description}</p>
            <div class="tool-meta">
              <span class="tool-category">{tool.category}</span>
              <span class="tool-released">{tool.released}</span>
            </div>
            <div class="tool-tags">
              {tool.tags.slice(0, 3).map(tag => (
                <span class="tool-tag">{tag}</span>
              ))}
            </div>
            <div class="tool-card-actions">
              <a href={`/tools/${tool.slug}/`} class="tool-link-details">Details →</a>
              <a href={tool.affiliateUrl || tool.url} target="_blank" rel="noopener" class="tool-link-visit">Visit ↗</a>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- All Tools -->
    <h2 style="font-size: 1.2rem; margin: 2rem 0 1rem;" id="all-tools-heading">All Tools</h2>
    <div class="tools-grid" id="tools-grid">
      {tools.map((tool) => (
        <div class="tool-card" data-category={tool.category} data-pricing={tool.pricing} data-name={tool.name.toLowerCase()} data-tags={tool.tags.join(',')} data-added={tool.added} data-url={`/tools/${tool.slug}/`}>
          <div class="tool-card-header">
            <h3><a href={`/tools/${tool.slug}/`}>{tool.name}</a></h3>
            <span class={`pricing-badge ${tool.pricing.toLowerCase()}`}>{tool.pricing}</span>
          </div>
          <p class="tool-description">{tool.description}</p>
          <div class="tool-meta">
            <span class="tool-category">{tool.category}</span>
            <span class="tool-released">{tool.released}</span>
          </div>
          <div class="tool-tags">
            {tool.tags.slice(0, 3).map(tag => (
              <span class="tool-tag">{tag}</span>
            ))}
          </div>
          <div class="tool-card-actions">
            <a href={`/tools/${tool.slug}/`} class="tool-link-details">Details →</a>
            <a href={tool.affiliateUrl || tool.url} target="_blank" rel="noopener" class="tool-link-visit">Visit ↗</a>
          </div>
        </div>
      ))}
    </div>

    <p class="no-results" id="no-results" style="display: none; text-align: center; color: var(--color-text-secondary); padding: 3rem 0;">
      No tools found matching your filters.
    </p>

    <!-- Pagination -->
    <div class="pagination" id="pagination">
      <button id="prev-btn" class="page-btn" disabled>← Prev</button>
      <div class="page-numbers" id="page-numbers"></div>
      <button id="next-btn" class="page-btn">Next →</button>
    </div>

    <p class="tool-count" id="tool-count" style="text-align: center; color: var(--color-text-secondary); margin-top: 1rem;">
      Page <span id="current-page">1</span> of <span id="total-pages">{totalPages}</span> · {tools.length} tools
    </p>
    </div>
  </section>
</BaseLayout>

<style>
  .directory-filters {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .filter-search {
    flex: 1;
    min-width: 200px;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
    color: var(--color-text);
    font-size: 0.95rem;
    transition: border-color 0.2s;
  }

  .filter-search:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .filter-group {
    display: flex;
    gap: 0.5rem;
  }

  .filter-select {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-card);
    color: var(--color-text);
    font-size: 0.9rem;
    cursor: pointer;
  }

  .filter-select:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .tool-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    transition: border-color 0.3s, box-shadow 0.3s;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    opacity: 0;
    transform: translateY(12px);
    animation: toolCardFadeIn 0.45s ease forwards;
  }

  .tool-card:nth-child(1) { animation-delay: 0.03s; }
  .tool-card:nth-child(2) { animation-delay: 0.06s; }
  .tool-card:nth-child(3) { animation-delay: 0.09s; }
  .tool-card:nth-child(4) { animation-delay: 0.12s; }
  .tool-card:nth-child(5) { animation-delay: 0.15s; }
  .tool-card:nth-child(6) { animation-delay: 0.18s; }
  .tool-card:nth-child(7) { animation-delay: 0.21s; }
  .tool-card:nth-child(8) { animation-delay: 0.24s; }
  .tool-card:nth-child(9) { animation-delay: 0.27s; }
  .tool-card:nth-child(10) { animation-delay: 0.3s; }
  .tool-card:nth-child(11) { animation-delay: 0.33s; }
  .tool-card:nth-child(12) { animation-delay: 0.36s; }

  @keyframes toolCardFadeIn {
    to { opacity: 1; transform: translateY(0); }
  }

  .tool-card a {
    color: inherit;
    text-decoration: none;
  }

  .tool-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), #ec4899, #f59e0b);
    background-size: 200% 100%;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }

  .tool-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 8px 25px rgba(124, 58, 237, 0.15);
  }

  .tool-card:hover::after {
    transform: scaleX(1);
    animation: gradientSlide 2s ease infinite;
  }

  @keyframes gradientSlide {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .tool-card.featured {
    border-color: rgba(124, 58, 237, 0.3);
    background: linear-gradient(135deg, var(--color-bg-card), var(--color-accent-light));
  }

  .tool-card.featured:hover {
    border-color: var(--color-accent);
    box-shadow: 0 8px 30px rgba(124, 58, 237, 0.2);
  }

  .featured-section {
    margin-bottom: 1rem;
  }

  .tool-card.hidden {
    display: none;
  }

  .tool-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .tool-card-header h3 { font-size: 1.1rem; font-weight: 700; }
  .tool-card-header a { color: var(--color-text); transition: color 0.2s; }
  .tool-card-header a:hover { color: var(--color-accent); }

  .pricing-badge {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 20px;
    white-space: nowrap;
  }

  .pricing-badge.free { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
  .pricing-badge.freemium { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
  .pricing-badge.paid { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }

  .tool-description {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .tool-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .tool-category { font-weight: 600; color: var(--color-accent); }

  .tool-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }

  .tool-tag {
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.7rem;
  }

  .tool-card-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid var(--color-border);
  }

  .tool-link-details {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .tool-link-visit {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    background: var(--color-bg-secondary);
    padding: 0.3rem 0.75rem;
    border-radius: 6px;
    transition: all 0.2s;
  }

  .tool-link-visit:hover { background: var(--color-accent); color: white; }

  /* Pagination */
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2rem;
  }

  .page-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-card);
    color: var(--color-text);
    cursor: pointer;
    font-weight: 600;
    font-size: 0.85rem;
    transition: all 0.2s;
  }

  .page-btn:hover:not(:disabled) {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .page-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .page-numbers {
    display: flex;
    gap: 0.25rem;
  }

  .page-num {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-card);
    color: var(--color-text);
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.2s;
  }

  .page-num:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .page-num.active { background: var(--color-accent); color: white; border-color: var(--color-accent); }

  @media (max-width: 768px) {
    .directory-filters { flex-direction: column; }
    .filter-group { flex-direction: column; }
    .tools-grid { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  const TOOLS_PER_PAGE = 12;
  const searchInput = document.getElementById('search');
  const categoryFilter = document.getElementById('category-filter');
  const pricingFilter = document.getElementById('pricing-filter');
  const sortSelect = document.getElementById('sort');
  const toolsGrid = document.getElementById('tools-grid');
  const noResults = document.getElementById('no-results');
  const paginationEl = document.getElementById('pagination');
  const pageNumbersEl = document.getElementById('page-numbers');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const currentPageEl = document.getElementById('current-page');
  const totalPagesEl = document.getElementById('total-pages');

  let currentPage = 1;
  let visibleCards = [];

  function getFilteredCards() {
    const search = searchInput.value.toLowerCase();
    const category = categoryFilter.value;
    const pricing = pricingFilter.value;
    const cards = Array.from(toolsGrid.querySelectorAll('.tool-card'));
    
    return cards.filter(card => {
      const name = card.dataset.name;
      const tags = card.dataset.tags;
      const cardCategory = card.dataset.category;
      const cardPricing = card.dataset.pricing;
      const matchesSearch = !search || name.includes(search) || tags.includes(search);
      const matchesCategory = !category || cardCategory === category;
      const matchesPricing = !pricing || cardPricing === pricing;
      return matchesSearch && matchesCategory && matchesPricing;
    });
  }

  function sortCards(cards) {
    const sort = sortSelect.value;
    return [...cards].sort((a, b) => {
      switch(sort) {
        case 'name': return a.dataset.name.localeCompare(b.dataset.name);
        case 'name-desc': return b.dataset.name.localeCompare(a.dataset.name);
        case 'newest': return (b.dataset.added || '').localeCompare(a.dataset.added || '');
        case 'oldest': return (a.dataset.added || '').localeCompare(b.dataset.added || '');
        default: return 0;
      }
    });
  }

  const featuredSection = document.getElementById('featured-section');

  // Make all tool cards clickable (featured + main grid)
  document.addEventListener('click', (e) => {
    const card = e.target.closest('.tool-card');
    const url = card?.dataset?.url;
    if (url && !e.target.closest('a, button, select')) {
      window.location.href = url;
    }
  });
  const allToolsHeading = document.getElementById('all-tools-heading');
  const hasFilters = () => searchInput.value || categoryFilter.value || pricingFilter.value;

  function renderPage() {
    const allCards = Array.from(toolsGrid.querySelectorAll('.tool-card'));
    allCards.forEach(c => c.classList.add('hidden'));

    // Show/hide featured section
    const showFeatured = !hasFilters() && currentPage === 1;
    featuredSection.style.display = showFeatured ? 'block' : 'none';
    
    // Update heading
    allToolsHeading.textContent = showFeatured ? 'All Tools' : 'Results';

    visibleCards = sortCards(getFilteredCards());
    const totalPages = Math.max(1, Math.ceil(visibleCards.length / TOOLS_PER_PAGE));
    
    if (currentPage > totalPages) currentPage = totalPages;
    
    const start = (currentPage - 1) * TOOLS_PER_PAGE;
    const end = start + TOOLS_PER_PAGE;
    let pageCards = visibleCards.slice(start, end);

    // On page 1 without filters, exclude featured tools (shown above)
    if (showFeatured) {
      pageCards = pageCards.filter(c => c.dataset.featured !== 'true');
    }

    pageCards.forEach((card, i) => {
      card.classList.remove('hidden');
      card.style.animation = `cardFadeIn 0.3s ease ${i * 0.03}s forwards`;
      toolsGrid.appendChild(card);
    });

    // Update pagination
    totalPagesEl.textContent = totalPages;
    currentPageEl.textContent = currentPage;
    prevBtn.disabled = currentPage <= 1;
    nextBtn.disabled = currentPage >= totalPages;

    // Page numbers
    pageNumbersEl.innerHTML = '';
    for (let i = 1; i <= totalPages; i++) {
      if (totalPages > 7) {
        if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
          const btn = document.createElement('span');
          btn.className = 'page-num' + (i === currentPage ? ' active' : '');
          btn.textContent = i;
          btn.onclick = () => goToPage(i);
          pageNumbersEl.appendChild(btn);
        } else if (i === currentPage - 2 || i === currentPage + 2) {
          const dots = document.createElement('span');
          dots.textContent = '...';
          dots.style.padding = '0 0.25rem';
          dots.style.color = 'var(--color-text-secondary)';
          pageNumbersEl.appendChild(dots);
        }
      } else {
        const btn = document.createElement('span');
        btn.className = 'page-num' + (i === currentPage ? ' active' : '');
        btn.textContent = i;
        btn.onclick = () => goToPage(i);
        pageNumbersEl.appendChild(btn);
      }
    }

    noResults.style.display = visibleCards.length === 0 ? 'block' : 'none';
    paginationEl.style.display = visibleCards.length > TOOLS_PER_PAGE ? 'flex' : 'none';
  }

  function goToPage(page) {
    currentPage = page;
    renderPage();
    window.scrollTo({ top: 200, behavior: 'smooth' });
  }

  prevBtn.onclick = () => goToPage(currentPage - 1);
  nextBtn.onclick = () => goToPage(currentPage + 1);

  searchInput.addEventListener('input', () => { currentPage = 1; renderPage(); });
  categoryFilter.addEventListener('change', () => { currentPage = 1; renderPage(); });
  pricingFilter.addEventListener('change', () => { currentPage = 1; renderPage(); });
  sortSelect.addEventListener('change', () => renderPage());

  // Initial render
  renderPage();
</script>
